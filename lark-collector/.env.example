# ============================================================
# 日周报分析助手 - 环境变量模板
# 复制本文件为 .env 再填写真实值
# ============================================================

# --- Model provider ---
MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.4
REVIEW_MODEL=gpt-5.4
MODEL_REASONING_EFFORT=xhigh
API_TIMEOUT=120

# --- Anthropic / Claude / proxy ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
CLAUDE_MODEL=claude-opus-4-1
CLAUDE_AUTH_MODE=auto

# --- OpenAI-compatible provider ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_WIRE_API=responses

# --- Feishu app credentials ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
BOT_DISPLAY_NAME=日周报分析助手

# --- Storage / reports ---
AUDIT_DB_PATH=
REPORTS_DIR=
PUBLIC_BASE_URL=https://agenthelpjob.com/bydfi-audit-bot
MAX_SOURCE_BODY_CHARS=20000

# --- Version plan (bitable, optional) ---
VERSION_PLAN_APP_TOKEN=
VERSION_PLAN_TABLE_ID=
VERSION_PLAN_VIEW_ID=
VERSION_PLAN_TITLE_FIELD=标题
VERSION_PLAN_OWNER_FIELD=负责人
VERSION_PLAN_STATUS_FIELD=状态
VERSION_PLAN_DUE_FIELD=截止时间

# --- Scheduled summary ---
GROUP_SUMMARY_CHAT_ID=
GROUP_SUMMARY_DEFAULT_HOURS=24
GROUP_SUMMARY_CRON_HOUR=18

# --- Department timeline tracking ---
DEPT_TRACKING_ENABLED=true
DEPT_TRACKING_CHAT_IDS=
DEPT_TRACKING_MIN_TEXT_LEN=400

# --- External Lark group collector ---
LARK_WEB_BASE_URL=https://www.larksuite.com
PLAYWRIGHT_STORAGE_STATE_PATH=
PLAYWRIGHT_BROWSER_CHANNEL=msedge
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO_MS=0
PLAYWRIGHT_NAV_TIMEOUT_MS=45000
EXTERNAL_GROUP_MESSAGE_SCAN_LIMIT=300
EXTERNAL_GROUP_SCROLL_ITERATIONS=18
EXTERNAL_GROUP_REPORT_KEYWORDS=周报,汇报,会议纪要,会议总结,会议记录,复盘,weekly report

# --- External group custom bot sender (optional) ---
CUSTOM_BOT_WEBHOOK_URL=

# --- Service ---
PORT=8080
DEBUG=false
